# MQTT parameters
[mqtt]
host = "localhost"
port = 1883
topic_base = "testbench/serial"

## By default, the bridge matches all serial ports on a system, but this can
## be limited with the usb_match list. This can specify one or more VID/PID
## patterns. Use "*" as a wildcard for either field.
#[[usb_match]]
#vid = "0403"   # FTDI
#pid = "6001"   # FT232RL
#[[usb_match]]
#vid = "0403"   # FTDI
#pid = "6010"   # FT2232H

## Equivalent "match everything" rule (implicit if usb_match is omitted):
# [[usb_match]]
# vid = "*"
# pid = "*"
